# ebook-sync 配置文件
# 
# 在此文件中定义默认参数，避免每次都指定命令行选项
# 
# 使用方法：编辑此文件后，脚本会自动加载这些设置
# 
# 命令行选项优先级高于配置文件设置

# ============================================================================
# 基本配置
# ============================================================================

# 本地源目录（存放电子书的目录）
SOURCE_DIR="${HOME}/Downloads"

# Kubernetes 上下文名称
KUBECONFIG_CONTEXT="k3s-homelab"

# calibre-web 所在的命名空间
NAMESPACE="personal-services"

# calibre-web Deployment 名称
DEPLOYMENT="calibre-web"

# calibre-web ingest 目录（Pod 内路径）
INGEST_DIR="/cwa-book-ingest"

# ============================================================================
# 操作配置
# ============================================================================

# 操作模式: "check" 或 "upload"
# check:  仅检查文件状态，不上传
# upload: 检查后上传新文件
# MODE="check"

# 干跑模式：模拟上传，不实际修改
# DRY_RUN=false

# 详细输出模式：显示更多调试信息和临时文件位置
# VERBOSE=false

# ============================================================================
# 高级配置
# ============================================================================

# 临时文件目录（不建议修改）
# TEMP_DIR="/tmp/ebook-sync-$$"

# 上传失败重试次数（如需实现）
# RETRY_COUNT=3

# ============================================================================
# 自定义过滤规则（可选）
# ============================================================================

# 如需添加自定义的非电子书过滤规则，可以在脚本中修改 is_non_ebook() 函数
# 
# 示例：
# is_non_ebook() {
#     local filename="$1"
#     
#     # 原有规则...
#     
#     # 添加自定义规则：过滤包含 "draft" 的文件
#     if [[ "${filename}" =~ draft ]]; then
#         return 0
#     fi
#     
#     return 1
# }

# ============================================================================
# 网络配置（如需要）
# ============================================================================

# kubectl 连接超时时间（秒）
# KUBECTL_TIMEOUT=30

# 上传文件超时时间（秒）
# UPLOAD_TIMEOUT=120
