# 隧道用通配路由 *.meirong.dev -> oracle cilium gateway（见 main.tf；服务地址是 var.gateway_service 默认值）。
# 子域名 DNS 由 external-dns（gateway-httproute source, txtOwnerId=oracle-externaldns）管理，
# 加子域名只需写一个 HTTPRoute，无需在此登记 —— 故不再需要 ingress_rules。
# rsshub is intentionally NOT exposed externally; only accessible within the cluster
# by miniflux via http://rsshub.rss-system.svc:1200
# terraform_managed_dns 默认空：仅当某子域名 DNS 必须由 terraform（而非 external-dns）管时才列出，如 ["foo"]。
terraform_managed_dns = []
