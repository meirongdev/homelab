# Show help
help:
    @just --list --unsorted

# Ping all hosts
ping:
    ansible-playbook playbooks/ping.yaml

# Install updates
install-updates:
    ansible-playbook playbooks/install-updates.yaml

# Download Ubuntu 24.04 LTS cloud image to Proxmox hosts
download-cloud-image:
    ansible-playbook playbooks/download-cloud-image.yaml

# 优化电源和散热（禁用 turbo boost、ASPM 省电、powertop 自动调优）
power-optimize:
    ansible-playbook playbooks/power-optimize.yaml

# pve-1 内置屏幕 10 分钟无操作后自动断电（console blank + DPMS powerdown）
console-screen-off:
    ansible-playbook playbooks/console-screen-off.yaml

# pve-1 屏幕断电健康检查（只读）：service / consoleblank / CRTC 状态
console-screen-check:
    ansible-playbook playbooks/console-screen-check.yaml

# pve-1 电源微调：ASPM 运行时生效 + USB 上行网卡禁 autosuspend + 电池限充 60%
power-tune-pve1:
    ansible-playbook playbooks/power-tune-pve1.yaml

# 部署 node_exporter (+ smartctl_exporter on storage) 到所有裸金属节点（106 + pve-1）
node-exporter:
    ansible-playbook playbooks/node-exporter-deploy.yaml

# 仅更新 storage 节点（106）的 exporter
node-exporter-storage:
    ansible-playbook playbooks/node-exporter-deploy.yaml --limit storage