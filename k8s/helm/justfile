    helm list -n {{namespace}} --kube-context {{ctx}}
    @echo ""
    @echo "=== Pods Status ==="
    kubectl --context {{ctx}} get pods -n {{namespace}} -o wide
    @echo ""
    @echo "=== Events (Recent) ==="
    kubectl --context {{ctx}} get events -n {{namespace}} --sort-by='.lastTimestamp' | tail -20
    @echo ""
    @echo "=== PVC Status ==="
    kubectl --context {{ctx}} get pvc -n {{namespace}}

# 查看失败的 pod 详情
debug-pods:
    #!/usr/bin/env bash
    echo "=== Checking for problematic pods ==="
    kubectl --context {{ctx}} get pods -n {{namespace}} | grep -v "Running\|Completed" || echo "All pods are running"
    echo ""
    echo "=== Describing non-running pods ==="
    for pod in $(kubectl --context {{ctx}} get pods -n {{namespace}} -o json | jq -r '.items[] | select(.status.phase!="Running" and .status.phase!="Succeeded") | .metadata.name'); do
        echo "--- Pod: $pod ---"
        kubectl --context {{ctx}} describe pod $pod -n {{namespace}} | tail -30
        echo ""
    done

