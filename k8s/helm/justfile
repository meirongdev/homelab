# ⬇️ Vault & Secret Management ⬇️
vault_ns := "vault"

deploy-vault:
    kubectl --context {{ctx}} create namespace {{vault_ns}} --dry-run=client -o yaml | kubectl --context {{ctx}} apply -f -
    helm upgrade --install vault hashicorp/vault \
        --namespace {{vault_ns}} \
        --kube-context {{ctx}} \
        --values values/vault-values.yaml

# 初始化 Vault (仅第一次运行)
vault-init:
    kubectl --context {{ctx}} exec vault-0 -n {{vault_ns}} -- vault operator init -key-shares=1 -key-threshold=1 -format=json > vault-keys.json
    @echo "✅ Vault initialized. Keys saved to vault-keys.json (DO NOT COMMIT THIS FILE)"

# 解锁 Vault (基于 vault-keys.json)
vault-unseal:
    #!/usr/bin/env bash
    set -euo pipefail
    key=$(jq -r ".unseal_keys_b64[0]" vault-keys.json)
    kubectl --context {{ctx}} exec vault-0 -n {{vault_ns}} -- vault operator unseal $key
    echo "✅ Vault unsealed."

# 部署 External Secrets Operator
deploy-eso:
    helm upgrade --install external-secrets external-secrets/external-secrets \
        --namespace external-secrets \
        --create-namespace \
        --kube-context {{ctx}} \
        --values values/external-secrets-values.yaml

# 配置 Vault 与 ESO 的连接 (需要先 init)
setup-vault-eso:
    #!/usr/bin/env bash
    set -euo pipefail
    token=$(jq -r ".root_token" vault-keys.json)
    kubectl --context {{ctx}} create secret generic vault-token \
        --namespace external-secrets \
        --from-literal=token=$token \
        --dry-run=client -o yaml | kubectl --context {{ctx}} apply -f -
    kubectl --context {{ctx}} apply -f manifests/vault-eso-config.yaml

# 备份 vault-keys.json 为 K8s Secret（防止丢失）
vault-backup-keys:
    #!/usr/bin/env bash
    set -euo pipefail
    kubectl --context {{ctx}} create secret generic vault-backup-keys \
        --namespace {{vault_ns}} \
        --from-literal=vault-keys.json="$(cat vault-keys.json)" \
        --dry-run=client -o yaml | kubectl --context {{ctx}} apply -f -
    echo "✅ vault-keys.json backed up to K8s secret vault/vault-backup-keys"

# ⬇️ ArgoCD GitOps ⬇️
argocd_ns := "argocd"

# Argo CD chart version — 调整前先 helm search repo argo/argo-cd 看最新
# 9.5.11 = appVersion v3.3.9（修 CVE-2026-42880；同小版本补丁升，避开 v3.4 迁移风险）。
# ⚠️ 这是 GitOps 控制器自升级：deploy-argocd 时若 gateway health 字段 SSA 冲突，加 --force-conflicts 重跑。
argocd_chart_version := "9.5.11"

# 一键安装 ArgoCD + 应用配置（幂等，可重复执行）
# 改为官方 Helm chart 部署（k8s/helm/values/argocd-values.yaml）
# 该 values 关闭了 dex/notifications/applicationSet 三个未使用组件、给所有组件加了 resources
deploy-argocd: add-repos
    # 1. 安装/升级 ArgoCD（CRD 由 chart 接管，重装时保留旧 CRD）
    helm upgrade --install argocd argo/argo-cd \
        --namespace {{argocd_ns}} \
        --create-namespace \
        --kube-context {{ctx}} \
        --version {{argocd_chart_version}} \
        --values values/argocd-values.yaml \
        --wait \
        --timeout 10m
    # 2. 注册 Gateway HTTPRoute（argocd namespace 已存在）
    kubectl --context {{ctx}} apply -f manifests/gateway.yaml
    # 3. 注册 AppProject + Applications
    kubectl --context {{ctx}} apply -f ../../argocd/projects/homelab.yaml
    kubectl --context {{ctx}} apply -f ../../argocd/applications/
    @echo "✅ ArgoCD deployed! Access at https://argocd.meirong.dev"
    @echo "Initial password: run 'just argocd-password'"

# 更新 Cloudflare DNS（添加 argocd.meirong.dev）
deploy-argocd-dns:
    cd ../../cloudflare/terraform && just apply

# 获取 ArgoCD 初始管理员密码
argocd-password:
    @kubectl --context {{ctx}} -n {{argocd_ns}} get secret argocd-initial-admin-secret -o jsonpath="{.data.password}" | base64 -d
    @echo ""

# 触发全量同步（通过 kubectl annotation，无需 argocd CLI）
argocd-sync:
    @echo "⏳ Triggering sync for all applications..."
    @kubectl --context {{ctx}} get applications -n {{argocd_ns}} -o name | xargs -I{} kubectl --context {{ctx}} annotate {} -n {{argocd_ns}} argocd.argoproj.io/refresh=normal --overwrite
    @echo "✅ Sync triggered. Waiting for completion..."
    @sleep 15
    @kubectl --context {{ctx}} get applications -n {{argocd_ns}}

# 查看所有 Application 状态
argocd-status:
    @echo "=== ArgoCD Applications ==="
    kubectl --context {{ctx}} get applications -n {{argocd_ns}}
    @echo ""
    @echo "=== ArgoCD Pods ==="
    kubectl --context {{ctx}} get pods -n {{argocd_ns}}

# ⬇️ Kopia Backup Server ⬇️
kopia_ns := "kopia"

# 添加 Kopia 服务器用户（格式: username@hostname）
kopia-add-user user:
    #!/usr/bin/env bash
    set -euo pipefail
    pod=$(kubectl --context {{ctx}} get pod -n {{kopia_ns}} -l app=kopia -o jsonpath='{.items[0].metadata.name}')
    password=$(kubectl --context {{ctx}} get secret -n {{kopia_ns}} kopia-secret -o jsonpath='{.data.password}' | base64 -d)
    kubectl --context {{ctx}} exec -n {{kopia_ns}} "$pod" -c kopia -- kopia server user add "{{user}}" --user-password="$password"
    kubectl --context {{ctx}} rollout restart deployment/kopia -n {{kopia_ns}}
    kubectl --context {{ctx}} rollout status deployment/kopia -n {{kopia_ns}} --timeout=90s
    echo "✅ User '{{user}}' added. Connect with:"
    echo "   kopia repository connect server \\"
    echo "     --url=https://10.10.10.10:31515 \\"
    echo "     --server-cert-fingerprint=$(just kopia-fingerprint) \\"
    echo "     --override-username=$(echo '{{user}}' | cut -d@ -f1)"

# 列出 Kopia 服务器用户
kopia-list-users:
    #!/usr/bin/env bash
    pod=$(kubectl --context {{ctx}} get pod -n {{kopia_ns}} -l app=kopia -o jsonpath='{.items[0].metadata.name}')
    kubectl --context {{ctx}} exec -n {{kopia_ns}} "$pod" -c kopia -- kopia server user list

# 获取 Kopia TLS 证书指纹
kopia-fingerprint:
    @openssl s_client -connect 10.10.10.10:31515 </dev/null 2>/dev/null | openssl x509 -fingerprint -sha256 -noout | sed 's/://g' | cut -d= -f2 | tr '[:upper:]' '[:lower:]'

# 查看 Kopia 服务器状态
kopia-status:
    @echo "=== Kopia Pods ==="
    @kubectl --context {{ctx}} get pods -n {{kopia_ns}}
    @echo ""
    @echo "=== Kopia PVCs ==="
    @kubectl --context {{ctx}} get pvc -n {{kopia_ns}}
    @echo ""
    @echo "=== Registered Users ==="
    @just kopia-list-users

# 配置 Vault 自动解锁（仅需运行一次）
# 从 vault-backup-keys 提取解锁密钥，创建 vault-auto-unseal secret
# 然后升级 Vault Helm Chart 以启用 postStart 自动解锁
vault-setup-auto-unseal:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "⏳ Extracting unseal key from vault-backup-keys secret..."
    UNSEAL_KEY=$(kubectl --context {{ctx}} get secret vault-backup-keys -n {{vault_ns}} \
        -o jsonpath='{.data.vault-keys\.json}' | base64 -d | \
        python3 -c "import json,sys; print(json.load(sys.stdin)['unseal_keys_b64'][0])")
    kubectl --context {{ctx}} create secret generic vault-auto-unseal -n {{vault_ns}} \
        --from-literal=unseal-key="$UNSEAL_KEY" --dry-run=client -o yaml | kubectl --context {{ctx}} apply -f -
    echo "⏳ Upgrading Vault Helm chart with auto-unseal postStart hook..."
    helm upgrade vault hashicorp/vault -n {{vault_ns}} --kube-context {{ctx}} -f values/vault-values.yaml
    echo "✅ Vault auto-unseal configured. Next restart will unseal automatically."

# 重启后健康检查（快速诊断断电恢复状态）
post-restart-check:
    @echo "=== Vault Status ==="
    @kubectl --context {{ctx}} exec -n {{vault_ns}} vault-0 -- vault status 2>/dev/null | grep -E "Sealed|HA Mode|Active Since" || echo "❌ Vault unreachable"
    @echo ""
    @echo "=== ExternalSecrets Sync Status ==="
    @kubectl --context {{ctx}} get externalsecret -A 2>/dev/null | grep -v "SecretSynced" | grep -v "^NAMESPACE" || echo "✅ All secrets synced"
    @echo ""
    @echo "=== Non-Running Pods ==="
    @kubectl --context {{ctx}} get pods -A --field-selector='status.phase!=Running,status.phase!=Succeeded' 2>/dev/null | grep -v "^NAMESPACE" || echo "✅ All pods running"
    @echo ""
    @echo "=== ArgoCD Insecure Mode (防止 redirect loop) ==="
    @kubectl --context {{ctx}} get configmap argocd-cmd-params-cm -n {{argocd_ns}} -o jsonpath='{.data.server\.insecure}' 2>/dev/null | grep -q "true" \
        && echo "✅ server.insecure=true (正常)" \
        || (echo "❌ server.insecure 未设置！请重跑 'just deploy-argocd' 让 Helm chart 重写 ConfigMap" && exit 1)
    @echo ""
    @echo "=== ArgoCD Apps ==="
    @kubectl --context {{ctx}} get applications -n {{argocd_ns}} 2>/dev/null

# Vault UI info
vault-ui:
    @echo "Vault UI is available at http://localhost:30820 (NodePort)"
    @echo "Root Token for login:"
    @jq -r ".root_token" vault-keys.json
    @echo "Starting port-forward to http://localhost:8200 ... Press Ctrl+C to stop."
    kubectl --context {{ctx}} port-forward -n {{vault_ns}} svc/vault 8200:8200

# 一键恢复 homelab cluster 在 VM 重启后的常见 stuck 状态：
#   1. unseal Vault（如果还密封）
#   2. 重启 ESO controller（让 ClusterSecretStore 重新 validate）
#   3. 重启 argocd-repo-server（DNS/Cilium bootstrap 期常踩 stuck）
#   4. 等所有 ExternalSecret SecretSynced + ArgoCD Apps Healthy
# 幂等，多跑无副作用。
homelab-recover:
    #!/usr/bin/env bash
    set -euo pipefail
    ctx="{{ctx}}"

    echo "▶ [1/5] Vault: wait for pod + API, then unseal only if sealed..."
    # keys file must be reachable (just runs recipes from k8s/helm, so relative path is fine)
    [ -f vault-keys.json ] || { echo "  ❌ vault-keys.json not found in $(pwd) — run from k8s/helm/"; exit 1; }

    # 1) wait for vault-0 to be Running. NOTE: a sealed Vault is deliberately NOT Ready,
    #    so we cannot use 'kubectl wait --for=condition=Ready' here — only phase=Running.
    phase=""
    for _ in $(seq 1 30); do   # up to 150s
        phase=$(kubectl --context "$ctx" get pod vault-0 -n {{vault_ns}} -o jsonpath='{.status.phase}' 2>/dev/null || true)
        [ "$phase" = "Running" ] && break
        sleep 5
    done
    [ "$phase" = "Running" ] || { echo "  ❌ vault-0 not Running after 150s (phase=$phase)"; exit 1; }

    # 2) poll until the Vault API gives a definitive answer.
    #    vault status exit codes: 0=unsealed, 2=sealed, anything else (1/126/137...)=not ready yet.
    sealed=""
    for _ in $(seq 1 30); do   # up to 150s
        set +e
        kubectl --context "$ctx" exec -n {{vault_ns}} vault-0 -- vault status >/dev/null 2>&1
        rc=$?
        set -e
        [ "$rc" -eq 0 ] && { sealed=false; break; }
        [ "$rc" -eq 2 ] && { sealed=true; break; }
        sleep 5
    done

    # 3) act on the definitive state — never silently assume "already unsealed"
    if [ "$sealed" = "true" ]; then
        echo "  Vault is sealed → unsealing from vault-keys.json"
        key=$(jq -r ".unseal_keys_b64[0]" vault-keys.json)
        kubectl --context "$ctx" exec -n {{vault_ns}} vault-0 -- vault operator unseal "$key" >/dev/null
        echo "  ✓ unsealed"
    elif [ "$sealed" = "false" ]; then
        echo "  ✓ Vault already unsealed"
    else
        echo "  ❌ Vault API never became reachable after 150s — aborting (check: kubectl logs vault-0 -n {{vault_ns}})"; exit 1
    fi

    echo "▶ [2/5] checking ClusterSecretStore validation..."
    if kubectl --context "$ctx" get clustersecretstore vault-backend -o jsonpath='{.status.conditions[0].status}' 2>/dev/null | grep -q "False"; then
        echo "  ClusterSecretStore is invalid, restarting ESO"
        kubectl --context "$ctx" rollout restart deployment external-secrets -n external-secrets
        kubectl --context "$ctx" rollout status deployment external-secrets -n external-secrets --timeout=90s
        echo "  ✓ ESO restarted"
    else
        echo "  ✓ ClusterSecretStore already valid"
    fi

    echo "▶ [3/5] re-applying CoreDNS public upstreams (k3s addon reverts forward to MagicDNS-tainted /etc/resolv.conf on restart; Tailscale MagicDNS can't resolve public names)..."
    cf=$(kubectl --context "$ctx" -n kube-system get configmap coredns -o jsonpath='{.data.Corefile}')
    newcf=$(printf '%s' "$cf" | sed 's|forward \. .*|forward . 1.1.1.1 8.8.8.8|')
    if [ "$cf" != "$newcf" ]; then
        kubectl --context "$ctx" -n kube-system patch configmap coredns --type merge -p "$(jq -n --arg c "$newcf" '{data:{Corefile:$c}}')"
        kubectl --context "$ctx" -n kube-system rollout restart deployment/coredns
        kubectl --context "$ctx" -n kube-system rollout status deployment/coredns --timeout=90s
        echo "  ✓ CoreDNS forward reset to public upstreams + restarted"
    else
        echo "  ✓ CoreDNS forward already public"
    fi

    echo "▶ [4/5] restarting argocd-repo-server (defensive — first sync after VM reboot tends to hang on DNS)..."
    kubectl --context "$ctx" rollout restart deployment/argocd-repo-server -n {{argocd_ns}}
    kubectl --context "$ctx" rollout status deployment/argocd-repo-server -n {{argocd_ns}} --timeout=90s
    echo "  ✓ argocd-repo-server restarted"

    echo "▶ [5/5] waiting for ExternalSecrets to converge..."
    # kubectl get externalsecret columns: NAMESPACE NAME STORETYPE STORE REFRESH STATUS READY
    for i in $(seq 1 12); do
        bad=$(kubectl --context "$ctx" get externalsecret -A --no-headers 2>/dev/null | awk '$6!="SecretSynced"' | wc -l | tr -d ' ')
        if [ "$bad" = "0" ]; then
            echo "  ✓ all ExternalSecrets synced"
            break
        fi
        printf "  [%ds] still not synced: %s\n" $((i*10)) "$bad"
        sleep 10
    done

    echo ""
    echo "=== final state ==="
    notsynced=$(kubectl --context "$ctx" get externalsecret -A --no-headers 2>/dev/null | awk '$6!="SecretSynced"')
    if [ -n "$notsynced" ]; then
        echo "$notsynced" | awk '{print "  ❌ " $0}'
    else
        echo "  ✓ all 12 ExternalSecrets SecretSynced"
    fi
    echo ""
    kubectl --context "$ctx" get applications -n {{argocd_ns}} 2>/dev/null
    echo ""
    echo "✅ homelab-recover done"

# ⬇️ 安全加固 (Pod Security Admission) ⬇️
#
# 给 homelab 各 namespace 打 Pod Security Admission 标签 —— 内置准入，零运行时开销，
# 即使 Kyverno 挂了也生效。这是 Pod 安全的"永远在线地板"。
#
# 为何用 just label 而不走 ArgoCD：本仓库 namespace 由 justfile/Helm/kustomize 混合创建，
# 没有任何 namespace 归专门的 ArgoCD Application 拥有。若用渲染整个 Namespace 对象的
# Application 来打标签，ArgoCD 会接管这些 namespace，配上普遍开启的 prune+selfHeal，
# 一次误同步就会 prune 删除 namespace 并级联删光里面的 PVC（Vault/postgres/kopia 数据）。
# kubectl label 纯元数据、幂等、不会删任何东西。oracle 侧的标签则在 kustomize 树的
# */namespace.yaml 里声明（那些 ns 本就被 kustomize 拥有，改现有资源无 prune 风险）。
#
# 等级（经实测各 namespace 特权情况，见 docs/runbooks/security-hardening.md）：
#   - baseline ns：实测零特权工作负载，安全 enforce
#   - privileged ns：kube-system(cilium/coredns)、monitoring(node-exporter/otel/grafana) 需特权，
#     显式标 privileged 文档化豁免；同时打 warn/audit=baseline 留审计线索（未来混入特权 Pod 可被发现）
# 注：PSA 仅在 Pod 创建/更新时评估，不影响已运行的 Pod；不在本阶段尝试 restricted（grafana 跑 root）。
psa_baseline_ns := "default vault zitadel kopia database bifrost personal-services cloudflare external-secrets argocd kyverno"
# trivy-system 保守标 privileged：扫描 Job 的 securityContext 由 operator 动态生成、不完全可控，
# 先不冒险 enforce baseline；warn/audit=baseline 会显示它是否其实合规，确认后可改 baseline。
psa_privileged_ns := "kube-system monitoring trivy-system tetragon"

harden-psa:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "▶ 应用 namespace → enforce=baseline (+ warn/audit=baseline)"
    for ns in {{psa_baseline_ns}}; do
        kubectl --context {{ctx}} label namespace "$ns" \
            pod-security.kubernetes.io/enforce=baseline \
            pod-security.kubernetes.io/enforce-version=latest \
            pod-security.kubernetes.io/warn=baseline \
            pod-security.kubernetes.io/warn-version=latest \
            pod-security.kubernetes.io/audit=baseline \
            pod-security.kubernetes.io/audit-version=latest \
            --overwrite
    done
    echo "▶ 系统 namespace → enforce=privileged (显式豁免, warn/audit 仍记 baseline)"
    for ns in {{psa_privileged_ns}}; do
        kubectl --context {{ctx}} label namespace "$ns" \
            pod-security.kubernetes.io/enforce=privileged \
            pod-security.kubernetes.io/warn=baseline \
            pod-security.kubernetes.io/warn-version=latest \
            pod-security.kubernetes.io/audit=baseline \
            pod-security.kubernetes.io/audit-version=latest \
            --overwrite
    done
    echo ""
    echo "✅ PSA 标签已应用。查看：kubectl --context {{ctx}} get ns -L pod-security.kubernetes.io/enforce"

# 查看 PSA 标签现状
psa-status:
    @echo "=== Namespace PSA enforce/warn 等级 ==="
    @kubectl --context {{ctx}} get ns -L pod-security.kubernetes.io/enforce,pod-security.kubernetes.io/warn
