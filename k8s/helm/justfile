# ⬇️ Vault & Secret Management ⬇️
vault_ns := "vault"

deploy-vault:
    kubectl --context {{ctx}} create namespace {{vault_ns}} --dry-run=client -o yaml | kubectl --context {{ctx}} apply -f -
    helm upgrade --install vault hashicorp/vault \
        --namespace {{vault_ns}} \
        --kube-context {{ctx}} \
        --values values/vault-values.yaml

# 初始化 Vault (仅第一次运行)
vault-init:
    kubectl --context {{ctx}} exec vault-0 -n {{vault_ns}} -- vault operator init -key-shares=1 -key-threshold=1 -format=json > vault-keys.json
    @echo "✅ Vault initialized. Keys saved to vault-keys.json (DO NOT COMMIT THIS FILE)"

# 解锁 Vault (基于 vault-keys.json)
vault-unseal:
    #!/usr/bin/env bash
    set -euo pipefail
    key=$(jq -r ".unseal_keys_b64[0]" vault-keys.json)
    kubectl --context {{ctx}} exec vault-0 -n {{vault_ns}} -- vault operator unseal $key
    echo "✅ Vault unsealed."

# 部署 External Secrets Operator
deploy-eso:
    helm upgrade --install external-secrets external-secrets/external-secrets \
        --namespace external-secrets \
        --create-namespace \
        --kube-context {{ctx}} \
        --values values/external-secrets-values.yaml

# 配置 Vault 与 ESO 的连接 (需要先 init)
setup-vault-eso:
    #!/usr/bin/env bash
    set -euo pipefail
    token=$(jq -r ".root_token" vault-keys.json)
    kubectl --context {{ctx}} create secret generic vault-token \
        --namespace external-secrets \
        --from-literal=token=$token \
        --dry-run=client -o yaml | kubectl --context {{ctx}} apply -f -
    kubectl --context {{ctx}} apply -f manifests/vault-eso-config.yaml

# 备份 vault-keys.json 为 K8s Secret（防止丢失）
vault-backup-keys:
    #!/usr/bin/env bash
    set -euo pipefail
    kubectl --context {{ctx}} create secret generic vault-backup-keys \
        --namespace {{vault_ns}} \
        --from-literal=vault-keys.json="$(cat vault-keys.json)" \
        --dry-run=client -o yaml | kubectl --context {{ctx}} apply -f -
    echo "✅ vault-keys.json backed up to K8s secret vault/vault-backup-keys"

# ⬇️ ArgoCD GitOps ⬇️
argocd_ns := "argocd"

# 一键安装 ArgoCD + 应用配置（幂等，可重复执行）
deploy-argocd:
    # 1. 创建 namespace（idempotent）
    kubectl --context {{ctx}} create namespace {{argocd_ns}} --dry-run=client -o yaml | kubectl --context {{ctx}} apply -f -
    # 2. 安装/更新 ArgoCD 核心组件（--server-side 避免 CRD 注释超限问题）
    kubectl --context {{ctx}} apply -n {{argocd_ns}} -f https://raw.githubusercontent.com/argoproj/argo-cd/stable/manifests/install.yaml --server-side
    @echo "⏳ Waiting for ArgoCD server to be ready..."
    kubectl --context {{ctx}} rollout status deployment/argocd-server -n {{argocd_ns}} --timeout=8m
    # 3. 禁用内置 TLS（由 Traefik 处理）
    # 注意：使用 --server-side 确保字段所有权，防止 install.yaml 重新 apply 后被覆盖
    kubectl --context {{ctx}} apply --server-side -f ../../argocd/install/argocd-cm-patch.yaml
    kubectl --context {{ctx}} rollout restart deployment/argocd-server -n {{argocd_ns}}
    kubectl --context {{ctx}} rollout status deployment/argocd-server -n {{argocd_ns}} --timeout=3m
    # 4. 注册 Gateway HTTPRoute（argocd namespace 已存在）
    kubectl --context {{ctx}} apply -f manifests/gateway.yaml
    # 5. 注册 AppProject + Applications
    kubectl --context {{ctx}} apply -f ../../argocd/projects/homelab.yaml
    kubectl --context {{ctx}} apply -f ../../argocd/applications/
    @echo "✅ ArgoCD deployed! Access at https://argocd.meirong.dev"
    @echo "Initial password: run 'just argocd-password'"

# 更新 Cloudflare DNS（添加 argocd.meirong.dev）
deploy-argocd-dns:
    cd ../../cloudflare/terraform && just apply

# 获取 ArgoCD 初始管理员密码
argocd-password:
    @kubectl --context {{ctx}} -n {{argocd_ns}} get secret argocd-initial-admin-secret -o jsonpath="{.data.password}" | base64 -d
    @echo ""

# 触发全量同步（通过 kubectl annotation，无需 argocd CLI）
argocd-sync:
    @echo "⏳ Triggering sync for all applications..."
    @kubectl --context {{ctx}} get applications -n {{argocd_ns}} -o name | xargs -I{} kubectl --context {{ctx}} annotate {} -n {{argocd_ns}} argocd.argoproj.io/refresh=normal --overwrite
    @echo "✅ Sync triggered. Waiting for completion..."
    @sleep 15
    @kubectl --context {{ctx}} get applications -n {{argocd_ns}}

# 查看所有 Application 状态
argocd-status:
    @echo "=== ArgoCD Applications ==="
    kubectl --context {{ctx}} get applications -n {{argocd_ns}}
    @echo ""
    @echo "=== ArgoCD Pods ==="
    kubectl --context {{ctx}} get pods -n {{argocd_ns}}

# ⬇️ Kopia Backup Server ⬇️
kopia_ns := "kopia"

# 添加 Kopia 服务器用户（格式: username@hostname）
kopia-add-user user:
    #!/usr/bin/env bash
    set -euo pipefail
    pod=$(kubectl --context {{ctx}} get pod -n {{kopia_ns}} -l app=kopia -o jsonpath='{.items[0].metadata.name}')
    password=$(kubectl --context {{ctx}} get secret -n {{kopia_ns}} kopia-secret -o jsonpath='{.data.password}' | base64 -d)
    kubectl --context {{ctx}} exec -n {{kopia_ns}} "$pod" -c kopia -- kopia server user add "{{user}}" --user-password="$password"
    kubectl --context {{ctx}} rollout restart deployment/kopia -n {{kopia_ns}}
    kubectl --context {{ctx}} rollout status deployment/kopia -n {{kopia_ns}} --timeout=90s
    echo "✅ User '{{user}}' added. Connect with:"
    echo "   kopia repository connect server \\"
    echo "     --url=https://10.10.10.10:31515 \\"
    echo "     --server-cert-fingerprint=$(just kopia-fingerprint) \\"
    echo "     --override-username=$(echo '{{user}}' | cut -d@ -f1)"

# 列出 Kopia 服务器用户
kopia-list-users:
    #!/usr/bin/env bash
    pod=$(kubectl --context {{ctx}} get pod -n {{kopia_ns}} -l app=kopia -o jsonpath='{.items[0].metadata.name}')
    kubectl --context {{ctx}} exec -n {{kopia_ns}} "$pod" -c kopia -- kopia server user list

# 获取 Kopia TLS 证书指纹
kopia-fingerprint:
    @openssl s_client -connect 10.10.10.10:31515 </dev/null 2>/dev/null | openssl x509 -fingerprint -sha256 -noout | sed 's/://g' | cut -d= -f2 | tr '[:upper:]' '[:lower:]'

# 查看 Kopia 服务器状态
kopia-status:
    @echo "=== Kopia Pods ==="
    @kubectl --context {{ctx}} get pods -n {{kopia_ns}}
    @echo ""
    @echo "=== Kopia PVCs ==="
    @kubectl --context {{ctx}} get pvc -n {{kopia_ns}}
    @echo ""
    @echo "=== Registered Users ==="
    @just kopia-list-users

# 配置 Vault 自动解锁（仅需运行一次）
# 从 vault-backup-keys 提取解锁密钥，创建 vault-auto-unseal secret
# 然后升级 Vault Helm Chart 以启用 postStart 自动解锁
vault-setup-auto-unseal:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "⏳ Extracting unseal key from vault-backup-keys secret..."
    UNSEAL_KEY=$(kubectl --context {{ctx}} get secret vault-backup-keys -n {{vault_ns}} \
        -o jsonpath='{.data.vault-keys\.json}' | base64 -d | \
        python3 -c "import json,sys; print(json.load(sys.stdin)['unseal_keys_b64'][0])")
    kubectl --context {{ctx}} create secret generic vault-auto-unseal -n {{vault_ns}} \
        --from-literal=key="$UNSEAL_KEY" --dry-run=client -o yaml | kubectl --context {{ctx}} apply -f -
    echo "⏳ Upgrading Vault Helm chart with auto-unseal postStart hook..."
    helm upgrade vault hashicorp/vault -n {{vault_ns}} --kube-context {{ctx}} -f values/vault-values.yaml
    echo "✅ Vault auto-unseal configured. Next restart will unseal automatically."

# 重启后健康检查（快速诊断断电恢复状态）
post-restart-check:
    @echo "=== Vault Status ==="
    @kubectl --context {{ctx}} exec -n {{vault_ns}} vault-0 -- vault status 2>/dev/null | grep -E "Sealed|HA Mode|Active Since" || echo "❌ Vault unreachable"
    @echo ""
    @echo "=== ExternalSecrets Sync Status ==="
    @kubectl --context {{ctx}} get externalsecret -A 2>/dev/null | grep -v "SecretSynced" | grep -v "^NAMESPACE" || echo "✅ All secrets synced"
    @echo ""
    @echo "=== Non-Running Pods ==="
    @kubectl --context {{ctx}} get pods -A --field-selector='status.phase!=Running,status.phase!=Succeeded' 2>/dev/null | grep -v "^NAMESPACE" || echo "✅ All pods running"
    @echo ""
    @echo "=== ArgoCD Insecure Mode (防止 redirect loop) ==="
    @kubectl --context {{ctx}} get configmap argocd-cmd-params-cm -n {{argocd_ns}} -o jsonpath='{.data.server\.insecure}' 2>/dev/null | grep -q "true" \
        && echo "✅ server.insecure=true (正常)" \
        || (echo "❌ server.insecure 未设置！正在修复..." && \
            kubectl --context {{ctx}} apply --server-side -f ../../argocd/install/argocd-cm-patch.yaml && \
            kubectl --context {{ctx}} rollout restart deployment/argocd-server -n {{argocd_ns}})
    @echo ""
    @echo "=== ArgoCD Apps ==="
    @kubectl --context {{ctx}} get applications -n {{argocd_ns}} 2>/dev/null

# Vault UI info
vault-ui:
    @echo "Vault UI is available at http://localhost:30820 (NodePort)"
    @echo "Root Token for login:"
    @jq -r ".root_token" vault-keys.json
    @echo "Starting port-forward to http://localhost:8200 ... Press Ctrl+C to stop."
    kubectl --context {{ctx}} port-forward -n {{vault_ns}} svc/vault 8200:8200
