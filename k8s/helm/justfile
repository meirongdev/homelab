    helm upgrade --install loki grafana/loki \
        --namespace {{namespace}} \
        --kube-context {{ctx}} \
        --values values/loki.yaml \
        --wait \
        --timeout 10m

deploy-tempo:
    helm upgrade --install tempo grafana/tempo \
        --namespace {{namespace}} \
        --kube-context {{ctx}} \
        --values values/tempo.yaml \
        --wait \
        --timeout 10m

