tunnel_id             = "ce9fd9fe-1dc4-430a-b797-b3b3fc931978"

# 隧道用通配路由 *.meirong.dev -> cilium gateway（见 main.tf；服务地址是 var.gateway_service 默认值）。
# 子域名 DNS 由 external-dns（gateway-httproute source）管理，加子域名只需写一个 HTTPRoute，
# 无需在此登记 —— 故不再需要 ingress_rules。
# terraform_managed_dns 默认空：仅当某子域名 DNS 必须由 terraform（而非 external-dns）管时才列出，如 ["foo"]。
terraform_managed_dns = []
