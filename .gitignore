# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Terraform lock file
.terraform.lock.hcl

# Terraform plan output
plan
plan.out
*.plan

# OS specific files
.DS_Store
.DS_Store?
._*

# Editor specific files
.vscode/
.idea/
*.swp
*.swo
*~

# Log files
*.log

# Environment variables
.env
!.env.example

# Vault keys
vault-keys.json

# Cloudflare credentials (NEVER commit)
cloudflare_credential.md

# Backup files
*.bak
*.tmp

# Merge conflict leftovers
*.orig

# Packer
credentials.pkr.hcl
variables.json
variables.auto.pkrvars.hcl

# Git worktrees
.worktrees/
**/vault_values.md

